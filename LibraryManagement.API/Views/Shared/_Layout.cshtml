<!DOCTYPE html>
<html lang="uk">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] – Бібліотека</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet" />
    <style>
        body { background-color: #f0f2f5; }

        #sidebar {
            width: 260px;
            min-height: 100vh;
            background: #1e2a3a;
            flex-shrink: 0;
            transition: width .25s;
        }

        #sidebar .sidebar-brand {
            padding: 1.25rem 1.5rem;
            border-bottom: 1px solid rgba(255,255,255,.1);
        }

        #sidebar .nav-link {
            color: #adb5bd;
            padding: .6rem 1.5rem;
            font-size: .9rem;
            border-radius: 0;
            display: flex;
            align-items: center;
            gap: .6rem;
        }

        #sidebar .nav-link:hover,
        #sidebar .nav-link.active {
            color: #fff;
            background: rgba(255,255,255,.08);
        }

        #sidebar .nav-section {
            padding: .9rem 1.5rem .3rem;
            font-size: .7rem;
            text-transform: uppercase;
            letter-spacing: .08em;
            color: #6c757d;
        }

        #page-content {
            flex: 1;
            overflow-x: hidden;
        }

        #topbar {
            background: #fff;
            border-bottom: 1px solid #dee2e6;
            padding: .75rem 1.5rem;
        }

        .card { border: none; box-shadow: 0 1px 4px rgba(0,0,0,.08); }

        .stat-card { border-left: 4px solid; }
        .stat-card.primary   { border-color: #0d6efd; }
        .stat-card.success   { border-color: #198754; }
        .stat-card.warning   { border-color: #ffc107; }
        .stat-card.danger    { border-color: #dc3545; }
        .stat-card.secondary { border-color: #6c757d; }

        .badge-active   { background: #d1e7dd; color: #0a3622; }
        .badge-returned { background: #cfe2ff; color: #084298; }
        .badge-overdue  { background: #f8d7da; color: #842029; }
    </style>
</head>
<body>
<div class="d-flex">

    <!-- SIDEBAR -->
    <nav id="sidebar">
        <div class="sidebar-brand">
            <a asp-controller="Home" asp-action="Index" class="text-decoration-none text-white fw-bold fs-5">
                <i class="fas fa-book-open me-2 text-primary"></i>Бібліотека
            </a>
        </div>

        <ul class="nav flex-column mt-2">
            <li class="nav-item">
                <a asp-controller="Home" asp-action="Index"
                   class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Home" ? "active" : "")">
                    <i class="fas fa-gauge-high"></i> Дашборд
                </a>
            </li>

            <div class="nav-section">Каталог</div>

            <li class="nav-item">
                <a asp-controller="Books" asp-action="Index"
                   class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Books" ? "active" : "")">
                    <i class="fas fa-book"></i> Книги
                </a>
            </li>

            @if (User.IsInRole("Admin") || User.IsInRole("Librarian"))
            {
                <div class="nav-section">Управління</div>

                <li class="nav-item">
                    <a asp-controller="Loans" asp-action="Index"
                       class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Loans" && ViewContext.RouteData.Values["action"]?.ToString() == "Index" ? "active" : "")">
                        <i class="fas fa-hand-holding-heart"></i> Видачі
                    </a>
                </li>
                <li class="nav-item">
                    <a asp-controller="Loans" asp-action="Overdue"
                       class="nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "Overdue" ? "active" : "")">
                        <i class="fas fa-clock-rotate-left text-danger"></i> Прострочені
                    </a>
                </li>
                <li class="nav-item">
                    <a asp-controller="Readers" asp-action="Index"
                       class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Readers" ? "active" : "")">
                        <i class="fas fa-users"></i> Читачі
                    </a>
                </li>
                <li class="nav-item">
                    <a asp-controller="Fines" asp-action="Index"
                       class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Fines" ? "active" : "")">
                        <i class="fas fa-file-invoice-dollar"></i> Штрафи
                    </a>
                </li>
            }
            else
            {
                <div class="nav-section">Мій акаунт</div>
                <li class="nav-item">
                    <a asp-controller="Loans" asp-action="MyLoans"
                       class="nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "MyLoans" ? "active" : "")">
                        <i class="fas fa-list-check"></i> Мої видачі
                    </a>
                </li>
                <li class="nav-item">
                    <a asp-controller="Fines" asp-action="MyFines"
                       class="nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "MyFines" ? "active" : "")">
                        <i class="fas fa-receipt"></i> Мої штрафи
                    </a>
                </li>
            }
        </ul>
    </nav>

    <!-- MAIN CONTENT -->
    <div id="page-content" class="d-flex flex-column">

        <!-- TOPBAR -->
        <div id="topbar" class="d-flex justify-content-between align-items-center">
            <h6 class="mb-0 text-muted">@ViewData["Title"]</h6>

            <div class="dropdown">
                <button class="btn btn-sm btn-outline-secondary dropdown-toggle" type="button" data-bs-toggle="dropdown">
                    <i class="fas fa-circle-user me-1"></i>@User.Identity?.Name
                </button>
                <ul class="dropdown-menu dropdown-menu-end shadow-sm">
                    <li>
                        <form asp-controller="Account" asp-action="Logout" method="post">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="dropdown-item text-danger">
                                <i class="fas fa-right-from-bracket me-2"></i>Вийти
                            </button>
                        </form>
                    </li>
                </ul>
            </div>
        </div>

        <!-- PAGE BODY -->
        <main class="p-4 flex-grow-1">

            @if (TempData["Success"] is string successMsg)
            {
                <div class="alert alert-success alert-dismissible fade show mb-3" role="alert">
                    <i class="fas fa-circle-check me-2"></i>@successMsg
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }
            @if (TempData["Error"] is string errorMsg)
            {
                <div class="alert alert-danger alert-dismissible fade show mb-3" role="alert">
                    <i class="fas fa-circle-exclamation me-2"></i>@errorMsg
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }

            @RenderBody()
        </main>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
