@model BookViewModel
@{ ViewData["Title"] = "Видалити книгу"; }

<div class="row justify-content-center">
    <div class="col-lg-6">
        <div class="card border-danger">
            <div class="card-header bg-danger text-white">
                <h5 class="mb-0"><i class="fas fa-triangle-exclamation me-2"></i>Підтвердження видалення</h5>
            </div>
            <div class="card-body">
                <p>Ви впевнені, що хочете видалити цю книгу?</p>
                <div class="bg-light rounded p-3 mb-4">
                    <div class="fw-bold">@Model.Title</div>
                    <div class="text-muted">@Model.Author, @Model.Year</div>
                    <div class="text-muted small font-monospace">@Model.ISBN</div>
                </div>
                <div class="d-flex gap-2">
                    <form asp-action="Delete" asp-route-id="@Model.Id" method="post">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-danger px-4">
                            <i class="fas fa-trash me-2"></i>Так, видалити
                        </button>
                    </form>
                    <a asp-action="Index" class="btn btn-outline-secondary">Скасувати</a>
                </div>
            </div>
        </div>
    </div>
</div>
