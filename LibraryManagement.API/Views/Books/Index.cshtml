@model IEnumerable<BookViewModel>
@{ ViewData["Title"] = "Книги"; }

<div class="card">
    <div class="card-header bg-white">
        <div class="d-flex flex-wrap gap-2 justify-content-between align-items-center">
            <form method="get" class="d-flex gap-2 flex-wrap">
                <input type="text" name="search" value="@ViewBag.Search" class="form-control form-control-sm" placeholder="Пошук за назвою..." style="width:220px;" />
                <input type="text" name="genre"  value="@ViewBag.Genre"  class="form-control form-control-sm" placeholder="Жанр..." style="width:140px;" />
                <button class="btn btn-sm btn-outline-secondary"><i class="fas fa-search me-1"></i>Знайти</button>
                @if (!string.IsNullOrEmpty(ViewBag.Search as string) || !string.IsNullOrEmpty(ViewBag.Genre as string))
                {
                    <a asp-action="Index" class="btn btn-sm btn-outline-danger"><i class="fas fa-xmark"></i></a>
                }
            </form>

            @if (User.IsInRole("Admin") || User.IsInRole("Librarian"))
            {
                <a asp-action="Create" class="btn btn-sm btn-primary">
                    <i class="fas fa-plus me-1"></i>Додати книгу
                </a>
            }
        </div>
    </div>

    <div class="card-body p-0">
        @if (!Model.Any())
        {
            <div class="text-center text-muted py-5">
                <i class="fas fa-book-open fa-2x mb-3 opacity-50"></i>
                <p>Книг не знайдено</p>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>#</th>
                            <th>Назва</th>
                            <th>Автор</th>
                            <th>Жанр</th>
                            <th>Рік</th>
                            <th class="text-center">Наявність</th>
                            <th>ISBN</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var book in Model)
                        {
                            <tr>
                                <td class="text-muted small">@book.Id</td>
                                <td class="fw-medium">@book.Title</td>
                                <td>@book.Author</td>
                                <td><span class="badge bg-secondary-subtle text-secondary">@book.Genre</span></td>
                                <td class="text-muted">@book.Year</td>
                                <td class="text-center">
                                    @if (book.IsAvailable)
                                    {
                                        <span class="badge bg-success-subtle text-success">
                                            @book.AvailableCopies / @book.TotalCopies
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger-subtle text-danger">Немає</span>
                                    }
                                </td>
                                <td class="text-muted small font-monospace">@book.ISBN</td>
                                <td>
                                    <div class="d-flex gap-1">
                                        <a asp-action="Details" asp-route-id="@book.Id" class="btn btn-sm btn-outline-secondary" title="Деталі">
                                            <i class="fas fa-eye"></i>
                                        </a>
                                        @if (User.IsInRole("Admin") || User.IsInRole("Librarian"))
                                        {
                                            <a asp-action="Edit" asp-route-id="@book.Id" class="btn btn-sm btn-outline-primary" title="Редагувати">
                                                <i class="fas fa-pen"></i>
                                            </a>
                                        }
                                        @if (User.IsInRole("Admin"))
                                        {
                                            <a asp-action="Delete" asp-route-id="@book.Id" class="btn btn-sm btn-outline-danger" title="Видалити">
                                                <i class="fas fa-trash"></i>
                                            </a>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
    <div class="card-footer bg-white text-muted small">
        Знайдено: @Model.Count() книг
    </div>
</div>
