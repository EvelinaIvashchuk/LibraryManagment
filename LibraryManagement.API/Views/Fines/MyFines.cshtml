@model IEnumerable<FineViewModel>
@{ ViewData["Title"] = "Мої штрафи"; }

<div class="card">
    <div class="card-header bg-white">
        <span class="fw-semibold">Мої штрафи</span>
    </div>
    <div class="card-body p-0">
        @if (!Model.Any())
        {
            <div class="text-center text-muted py-5">
                <i class="fas fa-circle-check fa-2x mb-3 text-success opacity-75"></i>
                <p>Штрафів немає</p>
            </div>
        }
        else
        {
            var unpaid = Model.Where(f => !f.IsPaid).Sum(f => f.Amount);
            if (unpaid > 0)
            {
                <div class="alert alert-warning m-3">
                    <i class="fas fa-triangle-exclamation me-2"></i>
                    Несплачено: <strong>@unpaid.ToString("F2") грн</strong>. Зверніться до бібліотеки.
                </div>
            }
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Книга</th>
                            <th>Причина</th>
                            <th>Сума</th>
                            <th>Дата</th>
                            <th>Статус</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var fine in Model)
                        {
                            <tr>
                                <td class="fw-medium">@fine.BookTitle</td>
                                <td class="text-muted small">@fine.Reason</td>
                                <td class="fw-bold @(fine.IsPaid ? "text-muted" : "text-danger")">
                                    @fine.Amount.ToString("F2") грн
                                </td>
                                <td class="text-muted small">@fine.CreatedAt.ToLocalTime().ToString("dd.MM.yyyy")</td>
                                <td>
                                    @if (fine.IsPaid)
                                    {
                                        <span class="badge bg-success-subtle text-success">Сплачено</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger-subtle text-danger">Не сплачено</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>
