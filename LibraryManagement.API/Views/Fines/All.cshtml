@model IEnumerable<FineViewModel>
@{ ViewData["Title"] = "Всі штрафи"; }

<div class="card">
    <div class="card-header bg-white d-flex justify-content-between align-items-center">
        <span class="fw-semibold">Всі штрафи</span>
        <a asp-action="Index" class="btn btn-sm btn-outline-danger">
            <i class="fas fa-filter me-1"></i>Лише несплачені
        </a>
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Читач</th>
                        <th>Книга</th>
                        <th>Причина</th>
                        <th>Сума</th>
                        <th>Нараховано</th>
                        <th>Статус</th>
                        <th>Сплачено</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var fine in Model)
                    {
                        <tr>
                            <td>
                                <a asp-controller="Readers" asp-action="Details" asp-route-id="@fine.ReaderId"
                                   class="text-decoration-none">@fine.ReaderName</a>
                            </td>
                            <td class="text-muted small">@fine.BookTitle</td>
                            <td class="text-muted small">@fine.Reason</td>
                            <td class="fw-bold @(fine.IsPaid ? "text-muted" : "text-danger")">
                                @fine.Amount.ToString("F2") грн
                            </td>
                            <td class="text-muted small">@fine.CreatedAt.ToLocalTime().ToString("dd.MM.yyyy")</td>
                            <td>
                                @if (fine.IsPaid)
                                {
                                    <span class="badge bg-success-subtle text-success">Сплачено</span>
                                }
                                else
                                {
                                    <span class="badge bg-danger-subtle text-danger">Не сплачено</span>
                                }
                            </td>
                            <td class="text-muted small">
                                @(fine.PaidAt.HasValue ? fine.PaidAt.Value.ToLocalTime().ToString("dd.MM.yyyy") : "—")
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
    <div class="card-footer bg-white text-muted small">
        Всього: @Model.Count() | Несплачено: @Model.Count(f => !f.IsPaid)
    </div>
</div>
