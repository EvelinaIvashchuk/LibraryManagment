@model IssueLoanDto
@{ ViewData["Title"] = "Видати книгу"; }

<div class="row justify-content-center">
    <div class="col-lg-6">
        <div class="card">
            <div class="card-header bg-white">
                <h5 class="mb-0"><i class="fas fa-hand-holding-heart me-2 text-success"></i>Видача книги</h5>
            </div>
            <div class="card-body">
                <form asp-action="Create" method="post">
                    @Html.AntiForgeryToken()
                    @if (!ViewData.ModelState.IsValid)
                    {
                        <div asp-validation-summary="All" class="alert alert-danger small py-2"></div>
                    }

                    <div class="mb-3">
                        <label asp-for="BookId" class="form-label fw-semibold"></label>
                        <select asp-for="BookId" asp-items="ViewBag.Books" class="form-select">
                            <option value="">— Оберіть книгу —</option>
                        </select>
                        <span asp-validation-for="BookId" class="text-danger small"></span>
                        <div class="form-text">Показано лише доступні для видачі книги</div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="ReaderId" class="form-label fw-semibold"></label>
                        <select asp-for="ReaderId" asp-items="ViewBag.Readers" class="form-select">
                            <option value="">— Оберіть читача —</option>
                        </select>
                        <span asp-validation-for="ReaderId" class="text-danger small"></span>
                        <div class="form-text">Показано лише незаблоковані читачі</div>
                    </div>

                    <div class="mb-4">
                        <label asp-for="DueDate" class="form-label fw-semibold"></label>
                        <input asp-for="DueDate" type="date" class="form-control"
                               min="@DateTime.Today.AddDays(1).ToString("yyyy-MM-dd")"
                               value="@DateTime.Today.AddDays(14).ToString("yyyy-MM-dd")" />
                        <span asp-validation-for="DueDate" class="text-danger small"></span>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-success px-4">
                            <i class="fas fa-hand-holding-heart me-2"></i>Видати
                        </button>
                        <a asp-action="Index" class="btn btn-outline-secondary">Скасувати</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts { @await Html.PartialAsync("_ValidationScriptsPartial") }
