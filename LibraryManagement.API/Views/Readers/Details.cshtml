@model ReaderViewModel
@using LibraryManagement.Core.Entities
@using LibraryManagement.Core.Entities.Enums
@{ ViewData["Title"] = Model.FullName; }

<div class="row g-4">
    <!-- Профіль -->
    <div class="col-lg-4">
        <div class="card">
            <div class="card-body text-center">
                <div class="bg-primary-subtle rounded-circle d-inline-flex align-items-center justify-content-center mb-3"
                     style="width:80px;height:80px;">
                    <i class="fas fa-user fa-2x text-primary"></i>
                </div>
                <h5 class="fw-bold">@Model.FullName</h5>
                <p class="text-muted small mb-1">@Model.Email</p>
                @if (!string.IsNullOrEmpty(Model.Phone))
                {
                    <p class="text-muted small mb-1"><i class="fas fa-phone me-1"></i>@Model.Phone</p>
                }
                @if (!string.IsNullOrEmpty(Model.Address))
                {
                    <p class="text-muted small"><i class="fas fa-location-dot me-1"></i>@Model.Address</p>
                }

                <hr />

                <div class="d-flex justify-content-around text-center">
                    <div>
                        <div class="fw-bold text-primary">@Model.ActiveLoans</div>
                        <div class="text-muted small">видач</div>
                    </div>
                    <div>
                        <div class="fw-bold text-danger">@Model.UnpaidFines.ToString("F2")</div>
                        <div class="text-muted small">штрафів грн</div>
                    </div>
                </div>

                <hr />

                <div class="mb-3">
                    @if (Model.IsBlocked)
                    {
                        <span class="badge bg-danger fs-6">Заблоковано</span>
                    }
                    else
                    {
                        <span class="badge bg-success fs-6">Активний</span>
                    }
                </div>

                @if (User.IsInRole("Admin"))
                {
                    @if (Model.IsBlocked)
                    {
                        <form asp-action="Unblock" asp-route-id="@Model.Id" method="post">
                            @Html.AntiForgeryToken()
                            <button class="btn btn-success btn-sm w-100">
                                <i class="fas fa-lock-open me-1"></i>Розблокувати
                            </button>
                        </form>
                    }
                    else
                    {
                        <form asp-action="Block" asp-route-id="@Model.Id" method="post">
                            @Html.AntiForgeryToken()
                            <button class="btn btn-danger btn-sm w-100">
                                <i class="fas fa-ban me-1"></i>Заблокувати
                            </button>
                        </form>
                    }
                }
            </div>
        </div>
    </div>

    <!-- Журнал видач -->
    <div class="col-lg-8">
        <div class="card">
            <div class="card-header bg-white">
                <span class="fw-semibold">Журнал видач</span>
            </div>
            <div class="card-body p-0">
                @{
                    var loans = ViewBag.Loans as List<Loan> ?? new List<Loan>();
                }
                @if (!loans.Any())
                {
                    <div class="text-center text-muted py-4">Видач немає</div>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-sm table-hover mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Книга</th>
                                    <th>Видано</th>
                                    <th>До</th>
                                    <th>Повернено</th>
                                    <th>Статус</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var loan in loans)
                                {
                                    <tr>
                                        <td class="small fw-medium">@loan.Book?.Title</td>
                                        <td class="small text-muted">@loan.IssuedAt.ToLocalTime().ToString("dd.MM.yyyy")</td>
                                        <td class="small @(loan.Status == LoanStatus.Active && loan.DueDate < DateTime.UtcNow ? "text-danger" : "")">
                                            @loan.DueDate.ToLocalTime().ToString("dd.MM.yyyy")
                                        </td>
                                        <td class="small text-muted">
                                            @(loan.ReturnedAt.HasValue ? loan.ReturnedAt.Value.ToLocalTime().ToString("dd.MM.yyyy") : "—")
                                        </td>
                                        <td>
                                            @switch (loan.Status)
                                            {
                                                case LoanStatus.Active when loan.DueDate < DateTime.UtcNow:
                                                    <span class="badge badge-overdue">Прострочено</span>
                                                    break;
                                                case LoanStatus.Active:
                                                    <span class="badge badge-active">Активна</span>
                                                    break;
                                                case LoanStatus.Returned:
                                                    <span class="badge badge-returned">Повернено</span>
                                                    break;
                                                default:
                                                    <span class="badge bg-secondary">@loan.Status</span>
                                                    break;
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    </div>
</div>
