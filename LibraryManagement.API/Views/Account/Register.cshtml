@model RegisterViewModel
@{ Layout = null; }
<!DOCTYPE html>
<html lang="uk">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Реєстрація – Бібліотека</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet" />
    <style>
        body { background: linear-gradient(135deg, #1e2a3a 0%, #2d4059 100%); min-height: 100vh; }
    </style>
</head>
<body class="d-flex align-items-center justify-content-center py-5">

<div class="card shadow-lg" style="width:480px;">
    <div class="card-body p-5">
        <div class="text-center mb-4">
            <i class="fas fa-user-plus fa-3x text-success mb-3"></i>
            <h4 class="fw-bold">Реєстрація читача</h4>
        </div>

        <form asp-action="Register" method="post">
            @Html.AntiForgeryToken()

            @if (!ViewData.ModelState.IsValid)
            {
                <div asp-validation-summary="All" class="alert alert-danger py-2 small"></div>
            }

            <div class="row g-3">
                <div class="col-12">
                    <label asp-for="FullName" class="form-label fw-semibold"></label>
                    <input asp-for="FullName" class="form-control" placeholder="Іван Петренко" />
                    <span asp-validation-for="FullName" class="text-danger small"></span>
                </div>

                <div class="col-12">
                    <label asp-for="Email" class="form-label fw-semibold"></label>
                    <input asp-for="Email" class="form-control" placeholder="ivan@example.com" />
                    <span asp-validation-for="Email" class="text-danger small"></span>
                </div>

                <div class="col-md-6">
                    <label asp-for="Password" class="form-label fw-semibold"></label>
                    <input asp-for="Password" class="form-control" placeholder="Мінімум 8 символів" />
                    <span asp-validation-for="Password" class="text-danger small"></span>
                </div>

                <div class="col-md-6">
                    <label asp-for="ConfirmPassword" class="form-label fw-semibold"></label>
                    <input asp-for="ConfirmPassword" class="form-control" placeholder="Повторіть пароль" />
                    <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                </div>

                <div class="col-md-6">
                    <label asp-for="Phone" class="form-label fw-semibold"></label>
                    <input asp-for="Phone" class="form-control" placeholder="+380" />
                </div>

                <div class="col-md-6">
                    <label asp-for="Address" class="form-label fw-semibold"></label>
                    <input asp-for="Address" class="form-control" placeholder="вул. Шевченка 1, Київ" />
                </div>

                <div class="col-12 mt-2">
                    <button type="submit" class="btn btn-success w-100 py-2 fw-semibold">
                        <i class="fas fa-user-plus me-2"></i>Зареєструватися
                    </button>
                </div>
            </div>
        </form>

        <div class="text-center mt-3">
            <span class="text-muted small">Вже є акаунт?</span>
            <a asp-action="Login" class="ms-1 small fw-semibold">Увійти</a>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
@await Html.PartialAsync("_ValidationScriptsPartial")
</body>
</html>
