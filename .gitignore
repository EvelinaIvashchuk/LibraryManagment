## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.
## See https://github.com/github/gitignore/blob/main/VisualStudio.gitignore

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates

# User-specific files (MonoDevelop/Xamarin Studio)
*.userprefs

# Mono auto generated files
mono_crash.*

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Xx]64/
[Xx]86/
[Aa]rm/
[Aa]rm64/
bld/
[Bb]in/
[Oo]bj/
[Ll]og/
[Ll]ogs/

# Visual Studio 2015/2017/2019/2022 cache/options directory
.vs/
# Uncomment if you have tasks that create the TestResults folder
#TestResults/

# ASYNC
# [Aa]sync/

# MSTest test Results
[Tt]est[Rr]esult*/
[Bb]uild[Ll]og.*

# NUnit
*.VisualState.xml
TestResult.xml
nunit-agent.log

# xUnit
xunit.performance.logger.ads

# ODP.NET Application Configuration
App.config

# EF Core Migrations
# *.designer.cs

# NuGet Packages
*.nupkg
# NuGet Symbol Packages
*.snupkg
# The packages folder can be ignored because of Package Restore
**/[Pp]ackages/*
# except build/, which is used as an MSBuild target.
!**/[Pp]ackages/build/
# Uncomment if using NuGet repositories to store project specific packages (not recommended)
# !packages/

# Microsoft Azure Build Output
csx/
*.build.csdef

# CodeAnalysis static analysis results
*.CodeAnalysisLog.xml
*.lastcodeanalysistitle.txt

# Entity Framework Core-specific files
*.efmigrate.sql

# Windows Azure Project Build Output
*.cscfg
*.csdef

# Rider
.idea/
*.sln.iml

# Visual Studio Code
.vscode/

# Temporary files from agent session
.output.txt
error.txt
output.txt

# End of standard Visual Studio gitignore
